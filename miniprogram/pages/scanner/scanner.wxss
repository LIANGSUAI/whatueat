.scanner-container {
  padding: 26rpx;
}

.scanner-header {
  padding-bottom: 22rpx;
  margin-bottom: 24rpx;
  border-bottom: 2rpx solid rgba(92, 102, 122, 0.08);
}

.scanner-subtitle {
  margin-top: 8rpx;
  color: #5c667a;
  font-size: 24rpx;
}

.scanner-workspace {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24rpx;
}

.dropzone-area,
.image-preview-wrapper {
  position: relative;
  display: flex;
  min-height: 520rpx;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx dashed rgba(22, 97, 171, 0.24);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.48);
}

.dropzone-content {
  width: 100%;
  padding: 60rpx 36rpx;
  text-align: center;
}

.upload-icon-circle,
.radar-scanner-circle {
  display: flex;
  width: 100rpx;
  height: 100rpx;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  border-radius: 50%;
  background: rgba(22, 97, 171, 0.08);
  color: #1661ab;
  box-shadow: 0 0 0 18rpx rgba(22, 97, 171, 0.04);
}

.upload-icon-circle::after,
.radar-scanner-circle::after {
  content: "";
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #1661ab;
}

.upload-prompt {
  margin-top: 30rpx;
  color: #1a2233;
  font-size: 34rpx;
  font-weight: 700;
}

.upload-subtext {
  margin-top: 12rpx;
  color: #5c667a;
  font-size: 24rpx;
}

.camera-option-tag {
  display: inline-flex;
  margin-top: 24rpx;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  background: rgba(244, 122, 56, 0.1);
  color: #f47a38;
  font-size: 22rpx;
  font-weight: 600;
}

.preview-image-img {
  width: 100%;
  height: 520rpx;
}

.scan-line {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 2;
  width: 100%;
  height: 6rpx;
  background: linear-gradient(90deg, transparent, #1661ab, transparent);
  box-shadow: 0 0 18rpx rgba(22, 97, 171, 0.6);
}

.preview-actions-overlay {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.overlay-btn {
  min-height: 74rpx;
}

.workspace-results-col {
  min-height: 360rpx;
}

.scanning-loader,
.results-empty-state {
  display: flex;
  min-height: 360rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.48);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  padding: 44rpx;
  text-align: center;
}

.loader-title,
.empty-title {
  margin-top: 28rpx;
  color: #1a2233;
  font-size: 30rpx;
  font-weight: 700;
}

.loader-desc,
.empty-desc {
  margin-top: 10rpx;
  color: #5c667a;
  font-size: 24rpx;
  line-height: 1.55;
}

.empty-book-art {
  border-radius: 18rpx;
  padding: 14rpx 24rpx;
  background: rgba(43, 164, 113, 0.09);
  color: #2ba471;
  font-size: 24rpx;
  font-weight: 700;
}

.scan-results-card {
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.48);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  padding: 22rpx;
}

.results-header-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.meal-type-selector-input {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  border-radius: 16rpx;
  padding: 0 18rpx;
  background: rgba(22, 97, 171, 0.08);
  color: #1661ab;
  font-size: 24rpx;
  font-weight: 700;
}

.small-btn {
  min-height: 64rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.meal-title-field {
  margin-top: 0;
}

.scanned-stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.scanned-stat-box {
  min-height: 128rpx;
  border-radius: 20rpx;
  padding: 14rpx 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.62);
  text-align: center;
}

.scanned-stat-box.orange {
  border-color: rgba(244, 122, 56, 0.18);
}

.scanned-stat-box.purple {
  border-color: rgba(22, 97, 171, 0.18);
}

.scanned-stat-box.yellow {
  border-color: rgba(255, 209, 17, 0.28);
}

.scanned-stat-box.danger {
  border-color: rgba(240, 55, 82, 0.18);
}

.scanned-stat-val {
  overflow: hidden;
  color: #1a2233;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scanned-stat-lbl {
  margin-top: 8rpx;
  color: #5c667a;
  font-size: 21rpx;
}

.result-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 14rpx;
}

.ingredients-breakdown-section {
  margin-top: 22rpx;
}

.ingredients-section-title {
  color: #1a2233;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.ingredient-item-card {
  border-radius: 16rpx;
  padding: 14rpx;
  margin-bottom: 10rpx;
  background: rgba(255, 255, 255, 0.54);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
}

.ingredient-display-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ing-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #f47a38;
}

.ing-name {
  color: #1a2233;
  font-weight: 700;
}

.ing-weight,
.ing-nutrients {
  color: #5c667a;
  font-size: 22rpx;
}

.scanned-actions-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.thumb-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 320px;
  height: 320px;
}
