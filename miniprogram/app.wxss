page {
  min-height: 100vh;
  background: linear-gradient(135deg, #fcfaf2 0%, #f0f5f8 50%, #eef7f2 100%);
  color: #1a2233;
  font-family: "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-size: 27rpx;
  font-weight: 400;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1.3;
  font-family: "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-size: 27rpx;
}

button::after {
  border: 0;
}

input,
textarea {
  width: 100%;
  min-height: 76rpx;
  border: 2rpx solid rgba(92, 102, 122, 0.26);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.86);
  padding: 0 22rpx;
  color: #1a2233;
  font-family: "PingFang SC", "SF Pro Text", -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-size: 27rpx;
}

textarea {
  min-height: 150rpx;
  padding-top: 18rpx;
  padding-bottom: 18rpx;
  line-height: 1.55;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
}

.section {
  margin-top: 24rpx;
}

.panel {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  padding: 26rpx;
  box-shadow: 0 24rpx 80rpx rgba(92, 102, 122, 0.08), 0 4rpx 10rpx rgba(26, 34, 51, 0.03);
}

.panel-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  color: #1a2233;
  font-size: 30rpx;
  font-weight: 700;
}

.muted {
  color: #5c667a;
}

.mini-text {
  color: #94a1b5;
  font-size: 24rpx;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.field {
  margin-top: 16rpx;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  color: #5c667a;
  font-size: 24rpx;
  font-weight: 700;
}

.primary-btn,
.secondary-btn,
.ghost-btn,
.danger-btn {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-weight: 600;
}

.primary-btn {
  background: linear-gradient(135deg, #1661ab 0%, #0d469b 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(22, 97, 171, 0.25);
}

.secondary-btn {
  background: linear-gradient(135deg, #818cf8 0%, #4f46e5 100%);
  color: #ffffff;
  border: 0;
  box-shadow: 0 10rpx 24rpx rgba(99, 102, 241, 0.22);
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.72);
  color: #1a2233;
  border: 2rpx solid rgba(255, 255, 255, 0.75);
}

.danger-btn {
  background: rgba(240, 55, 82, 0.09);
  color: #f03752;
  border: 2rpx solid rgba(240, 55, 82, 0.16);
}

.pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  background: rgba(43, 164, 113, 0.1);
  color: #2ba471;
  font-size: 24rpx;
  font-weight: 600;
}

.empty {
  padding: 54rpx 20rpx;
  color: #94a1b5;
  text-align: center;
  line-height: 1.55;
}

.card-title {
  color: #1a2233;
  font-size: 30rpx;
  font-weight: 700;
}

.glass-card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  box-shadow: 0 24rpx 80rpx rgba(92, 102, 122, 0.08), 0 4rpx 10rpx rgba(26, 34, 51, 0.03);
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
